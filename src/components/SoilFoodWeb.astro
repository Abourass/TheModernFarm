---
// Animated soil food web hero diagram.
// Canvas-based: 10 nodes (Sun → Plant → Roots/OM → Bacteria/Fungi →
// Protozoa/Nematodes → Earthworms → CO₂/Nutrients), 18 directed edges
// with flowing color-coded particles, pulsing nodes, hover highlight,
// and full dark/light theme support driven by `<html class="dark-theme">`.
---

<div class="sfweb">
	<canvas
		class="sfweb-canvas"
		width="480"
		height="560"
		aria-label="Animated soil food web diagram showing energy and nutrient flow between sun, plants, roots, organic matter, bacteria, fungi, protozoa, nematodes and earthworms"
	></canvas>
	<ul class="sfweb-legend">
		<li><span class="dot" style="background:#ea580c"></span>Energy</li>
		<li><span class="dot" style="background:#16a34a"></span>Plant</li>
		<li><span class="dot" style="background:#a16207"></span>Detritus</li>
		<li><span class="dot" style="background:#8b5cf6"></span>Microbes</li>
		<li><span class="dot" style="background:#0891b2"></span>Cycling</li>
		<li><span class="dot" style="background:#78716c"></span>Fauna</li>
	</ul>
	<div class="sfweb-tooltip" hidden>
		<div class="name"></div>
		<div class="sub"></div>
	</div>
</div>

<style>
	.sfweb {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 12px;
		flex-shrink: 0;
	}

	.sfweb-canvas {
		display: block;
		width: 480px;
		height: 560px;
		max-width: 100%;
		border-radius: 12px;
		background: var(--stone-100);
		cursor: crosshair;
	}

	.sfweb-legend {
		display: flex;
		flex-wrap: wrap;
		gap: 6px 18px;
		padding: 0 2px;
		margin: 0;
		list-style: none;
	}
	.sfweb-legend li {
		display: flex;
		align-items: center;
		gap: 6px;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.67rem;
		letter-spacing: 0.04em;
		color: rgb(var(--gray));
	}
	.sfweb-legend .dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.sfweb-tooltip {
		position: fixed;
		pointer-events: none;
		background: var(--stone-50);
		border: 1px solid var(--stone-200);
		border-radius: 8px;
		padding: 7px 13px;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.72rem;
		color: rgb(var(--gray-dark));
		box-shadow: 0 4px 12px rgba(var(--gray), 12%);
		z-index: 99;
		transform: translate(14px, -50%);
		white-space: nowrap;
		transition: opacity 0.15s ease;
	}
	:root.dark-theme .sfweb-tooltip {
		background: var(--stone-100);
		border-color: var(--stone-200);
	}
	.sfweb-tooltip .name {
		font-weight: 600;
	}
	.sfweb-tooltip .sub {
		color: rgb(var(--gray));
		margin-top: 2px;
	}

	@media (max-width: 860px) {
		.sfweb {
			align-items: center;
			width: 100%;
		}
		.sfweb-canvas {
			width: 100%;
			height: auto;
			aspect-ratio: 480 / 560;
		}
	}
</style>

<script>
	const CW = 480;
	const CH = 560;

	type Node = {
		id: string;
		label: string;
		sub: string;
		x: number;
		y: number;
		r: number;
		color: string;
	};
	type Edge = { from: string; to: string; curve: number };

	const NODES: Node[] = [
		{ id: "sun", label: "Solar Energy", sub: "Energy Input", x: 240, y: 54, r: 20, color: "#ea580c" },
		{ id: "plant", label: "Plant", sub: "Producer", x: 240, y: 128, r: 22, color: "#16a34a" },
		{ id: "co2", label: "CO₂ / Nutrients", sub: "Mineral Cycle", x: 408, y: 210, r: 16, color: "#0891b2" },
		{ id: "om", label: "Organic Matter", sub: "Detritus", x: 72, y: 214, r: 18, color: "#a16207" },
		{ id: "roots", label: "Root Zone", sub: "Rhizosphere", x: 240, y: 220, r: 19, color: "#16a34a" },
		{ id: "bacteria", label: "Bacteria", sub: "Decomposer", x: 70, y: 338, r: 17, color: "#8b5cf6" },
		{ id: "fungi", label: "Mycorrhizal Fungi", sub: "Symbiont", x: 232, y: 346, r: 18, color: "#8b5cf6" },
		{ id: "protozoa", label: "Protozoa", sub: "Bacterivore", x: 72, y: 462, r: 14, color: "#0891b2" },
		{ id: "nematodes", label: "Nematodes", sub: "Consumer", x: 368, y: 400, r: 15, color: "#78716c" },
		{ id: "worms", label: "Earthworms", sub: "Decomposer", x: 232, y: 500, r: 17, color: "#a16207" },
	];

	const EDGES: Edge[] = [
		{ from: "sun", to: "plant", curve: 0.0 },
		{ from: "plant", to: "roots", curve: 0.0 },
		{ from: "plant", to: "om", curve: -0.12 },
		{ from: "co2", to: "plant", curve: -0.15 },
		{ from: "roots", to: "bacteria", curve: -0.1 },
		{ from: "roots", to: "fungi", curve: 0.0 },
		{ from: "om", to: "bacteria", curve: 0.0 },
		{ from: "om", to: "fungi", curve: 0.15 },
		{ from: "om", to: "worms", curve: 0.15 },
		{ from: "bacteria", to: "protozoa", curve: 0.0 },
		{ from: "bacteria", to: "nematodes", curve: -0.12 },
		{ from: "fungi", to: "nematodes", curve: -0.1 },
		{ from: "protozoa", to: "worms", curve: -0.15 },
		{ from: "nematodes", to: "worms", curve: -0.08 },
		{ from: "worms", to: "om", curve: 0.2 },
		{ from: "bacteria", to: "co2", curve: -0.18 },
		{ from: "fungi", to: "co2", curve: -0.12 },
		{ from: "worms", to: "co2", curve: -0.18 },
	];

	const SEPARATORS = [
		{ y: 176, label: "Producers" },
		{ y: 290, label: "Decomposers" },
		{ y: 415, label: "Consumers" },
	];

	const nodeMap: Record<string, Node> = Object.fromEntries(NODES.map((n) => [n.id, n]));

	function edgeControlPt(from: Node, to: Node, curvature: number) {
		const mx = (from.x + to.x) / 2;
		const my = (from.y + to.y) / 2;
		const dx = to.x - from.x;
		const dy = to.y - from.y;
		return { cx: mx - dy * curvature, cy: my + dx * curvature };
	}

	function bezierAt(p0x: number, p0y: number, cpx: number, cpy: number, p1x: number, p1y: number, t: number) {
		const mt = 1 - t;
		return {
			x: mt * mt * p0x + 2 * mt * t * cpx + t * t * p1x,
			y: mt * mt * p0y + 2 * mt * t * cpy + t * t * p1y,
		};
	}

	function hexRgb(hex: string): [number, number, number] {
		return [
			parseInt(hex.slice(1, 3), 16),
			parseInt(hex.slice(3, 5), 16),
			parseInt(hex.slice(5, 7), 16),
		];
	}

	type Particle = { ei: number; t: number; speed: number };

	function initSoilFoodWeb(root: HTMLElement) {
		const canvas = root.querySelector<HTMLCanvasElement>(".sfweb-canvas");
		const tooltip = root.querySelector<HTMLElement>(".sfweb-tooltip");
		if (!canvas || !tooltip) return;
		const ctx = canvas.getContext("2d");
		if (!ctx) return;
		const tooltipName = tooltip.querySelector<HTMLElement>(".name")!;
		const tooltipSub = tooltip.querySelector<HTMLElement>(".sub")!;

		const particles: Particle[] = [];
		EDGES.forEach((_edge, ei) => {
			const count = 4;
			for (let i = 0; i < count; i++) {
				particles.push({
					ei,
					t: i / count + Math.random() * 0.15,
					speed: 0.0016 + Math.random() * 0.0014,
				});
			}
		});

		let hovered: string | null = null;
		let dark = document.documentElement.classList.contains("dark-theme");
		let animId = 0;

		function paletteFor(isDark: boolean) {
			return {
				BG: isDark ? "#1c1917" : "#fafaf9",
				GRID: isDark ? "rgba(255,255,255,0.03)" : "rgba(0,0,0,0.035)",
				EDGE_DIM: isDark ? "rgba(255,255,255,0.08)" : "rgba(0,0,0,0.08)",
				LABEL_C: isDark ? "rgba(250,250,249,0.78)" : "rgba(28,25,23,0.78)",
				SUB_C: isDark ? "rgba(250,250,249,0.32)" : "rgba(28,25,23,0.34)",
				SEP_C: isDark ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.055)",
				SEP_TXT: isDark ? "rgba(255,255,255,0.18)" : "rgba(0,0,0,0.20)",
			};
		}

		function frame(ts: number) {
			if (!ctx) return;
			const p = paletteFor(dark);
			ctx.clearRect(0, 0, CW, CH);

			ctx.fillStyle = p.BG;
			ctx.fillRect(0, 0, CW, CH);

			ctx.strokeStyle = p.GRID;
			ctx.lineWidth = 1;
			for (let x = 0; x <= CW; x += 40) {
				ctx.beginPath();
				ctx.moveTo(x, 0);
				ctx.lineTo(x, CH);
				ctx.stroke();
			}
			for (let y = 0; y <= CH; y += 40) {
				ctx.beginPath();
				ctx.moveTo(0, y);
				ctx.lineTo(CW, y);
				ctx.stroke();
			}

			ctx.save();
			ctx.setLineDash([3, 6]);
			ctx.lineWidth = 1;
			SEPARATORS.forEach((sep) => {
				ctx.strokeStyle = p.SEP_C;
				ctx.beginPath();
				ctx.moveTo(0, sep.y);
				ctx.lineTo(CW, sep.y);
				ctx.stroke();

				ctx.font = '500 8px "JetBrains Mono", monospace';
				ctx.fillStyle = p.SEP_TXT;
				ctx.textAlign = "right";
				ctx.textBaseline = "bottom";
				ctx.fillText("— " + sep.label, CW - 6, sep.y - 3);
			});
			ctx.setLineDash([]);
			ctx.restore();

			EDGES.forEach((edge) => {
				const fn = nodeMap[edge.from];
				const tn = nodeMap[edge.to];
				const { cx, cy } = edgeControlPt(fn, tn, edge.curve);

				const isActive = hovered && (edge.from === hovered || edge.to === hovered);
				const isDimmed = hovered && !isActive;

				if (isDimmed) {
					ctx.strokeStyle = p.EDGE_DIM;
					ctx.lineWidth = 0.75;
				} else if (isActive) {
					const [r, g, b] = hexRgb(fn.color);
					ctx.strokeStyle = `rgba(${r},${g},${b},0.5)`;
					ctx.lineWidth = 1.5;
				} else {
					ctx.strokeStyle = p.EDGE_DIM;
					ctx.lineWidth = 1;
				}

				ctx.beginPath();
				ctx.moveTo(fn.x, fn.y);
				ctx.quadraticCurveTo(cx, cy, tn.x, tn.y);
				ctx.stroke();

				const tip = bezierAt(fn.x, fn.y, cx, cy, tn.x, tn.y, 0.86);
				const back = bezierAt(fn.x, fn.y, cx, cy, tn.x, tn.y, 0.8);
				const ang = Math.atan2(tip.y - back.y, tip.x - back.x);
				const as = isDimmed ? 4 : 5;

				ctx.save();
				ctx.translate(tip.x, tip.y);
				ctx.rotate(ang);
				ctx.beginPath();
				ctx.moveTo(0, 0);
				ctx.lineTo(-as, -as * 0.48);
				ctx.lineTo(-as, as * 0.48);
				ctx.closePath();
				ctx.fillStyle = ctx.strokeStyle as string;
				ctx.fill();
				ctx.restore();
			});

			particles.forEach((pt) => {
				pt.t += pt.speed;
				if (pt.t >= 1) pt.t -= 1;

				const edge = EDGES[pt.ei];
				const fn = nodeMap[edge.from];
				const tn = nodeMap[edge.to];
				const { cx, cy } = edgeControlPt(fn, tn, edge.curve);

				const isActive = hovered && (edge.from === hovered || edge.to === hovered);
				const isDimmed = hovered && !isActive;
				if (isDimmed) return;

				const pos = bezierAt(fn.x, fn.y, cx, cy, tn.x, tn.y, pt.t);
				const fade = pt.t < 0.12 ? pt.t / 0.12 : pt.t > 0.88 ? (1 - pt.t) / 0.12 : 1;
				const [r, g, b] = hexRgb(fn.color);
				const a = fade * (isActive ? 1.0 : 0.72);
				const pr = isActive ? 3.2 : 2.6;

				ctx.beginPath();
				ctx.arc(pos.x, pos.y, pr * 2.8, 0, Math.PI * 2);
				ctx.fillStyle = `rgba(${r},${g},${b},${fade * 0.14})`;
				ctx.fill();

				ctx.beginPath();
				ctx.arc(pos.x, pos.y, pr, 0, Math.PI * 2);
				ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
				ctx.fill();
			});

			NODES.forEach((node) => {
				const isH = hovered === node.id;
				const isDim = hovered && !isH;
				const pulse = 1 + Math.sin(ts * 0.0009 + node.x * 0.015) * 0.06;
				const nr = node.r * (isH ? 1.18 : pulse);
				const [r, g, b] = hexRgb(node.color);

				if (!isDim) {
					const glowR = nr * (isH ? 3.0 : 2.2);
					const grad = ctx.createRadialGradient(node.x, node.y, nr * 0.4, node.x, node.y, glowR);
					grad.addColorStop(0, `rgba(${r},${g},${b},${isH ? 0.28 : 0.14})`);
					grad.addColorStop(1, `rgba(${r},${g},${b},0)`);
					ctx.beginPath();
					ctx.arc(node.x, node.y, glowR, 0, Math.PI * 2);
					ctx.fillStyle = grad;
					ctx.fill();
				}

				ctx.beginPath();
				ctx.arc(node.x, node.y, nr, 0, Math.PI * 2);
				ctx.fillStyle = isDim
					? `rgba(${r},${g},${b},0.18)`
					: `rgba(${r},${g},${b},${isH ? 1 : 0.88})`;
				ctx.fill();

				ctx.beginPath();
				ctx.arc(node.x, node.y, nr, 0, Math.PI * 2);
				ctx.strokeStyle = isDim
					? `rgba(${r},${g},${b},0.08)`
					: `rgba(${r},${g},${b},${isH ? 0.6 : 0.35})`;
				ctx.lineWidth = isH ? 2 : 1;
				ctx.stroke();

				const labelY = node.y + nr + 5;
				ctx.font = '500 9.5px "JetBrains Mono", monospace';
				ctx.textAlign = "center";
				ctx.textBaseline = "top";
				ctx.fillStyle = isDim
					? `rgba(${r},${g},${b},0.22)`
					: isH
						? `rgba(${r},${g},${b},1)`
						: p.LABEL_C;
				ctx.fillText(node.label, node.x, labelY);

				ctx.font = '400 8px "JetBrains Mono", monospace';
				ctx.fillStyle = isDim ? `rgba(${r},${g},${b},0.10)` : p.SUB_C;
				ctx.fillText(node.sub.toUpperCase(), node.x, labelY + 13);
			});

			animId = requestAnimationFrame(frame);
		}

		canvas.addEventListener("mousemove", (e) => {
			const rect = canvas.getBoundingClientRect();
			const scaleX = CW / rect.width;
			const scaleY = CH / rect.height;
			const mx = (e.clientX - rect.left) * scaleX;
			const my = (e.clientY - rect.top) * scaleY;

			let hit: string | null = null;
			let best = 999;
			NODES.forEach((node) => {
				const d = Math.hypot(node.x - mx, node.y - my);
				if (d < node.r + 14 && d < best) {
					best = d;
					hit = node.id;
				}
			});
			hovered = hit;

			if (hit) {
				const node = nodeMap[hit];
				tooltip.hidden = false;
				tooltip.style.top = `${e.clientY}px`;
				tooltip.style.left = `${e.clientX}px`;
				tooltipName.textContent = node.label;
				tooltipName.style.color = node.color;
				tooltipSub.textContent = node.sub;
			} else {
				tooltip.hidden = true;
			}
		});

		canvas.addEventListener("mouseleave", () => {
			hovered = null;
			tooltip.hidden = true;
		});

		const themeObserver = new MutationObserver(() => {
			dark = document.documentElement.classList.contains("dark-theme");
		});
		themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

		frame(performance.now());

		// Pause when hidden so we don't burn cycles in background tabs
		document.addEventListener("visibilitychange", () => {
			if (document.hidden) {
				cancelAnimationFrame(animId);
			} else {
				animId = requestAnimationFrame(frame);
			}
		});
	}

	document.querySelectorAll<HTMLElement>(".sfweb").forEach(initSoilFoodWeb);
</script>
